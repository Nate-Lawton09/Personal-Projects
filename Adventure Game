dice = [1,2,3,4,5,6]


def dice_roll():

    user_input = 0
    flag = False
    while flag != True:
        for i in range(len(dice)):
        
            try:
                user_input = inputimeout( prompt = f">> {dice[i]}" , timeout = 0.2)
            except:
              
                print("\033[F\033[K", end="")
                
            else:
                user_input = dice[i]
                flag = True
                break
    return user_input

