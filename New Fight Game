        break
                 


    return gold , Health , Defence , magic_tokens

#System##########################################################################################################################################

def sys_loop( Level , Health , Defence , xp , gold , Attack_Power , Magic_Power , magic_tokens , win , end_match , Dead):
    while True:
        win = False
        end_match = False
        Level , xp , Magic_Power , Attack_Power = level_up(Level , xp , Magic_Power , Attack_Power)
        choice = Main_Menu()

        if choice == "1":
            enemy = enemy_select()
            start = decide_starter()
            Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power = enemy_scaling(enemy , Level)


            while end_match == False:
                if start == True:
                    Enemy_Health , Enemy_Defence , magic_tokens = player_turn(Enemy_Health , Enemy_Defence , Health , Attack_Power , Magic_Power , magic_tokens)
                    end_match  , win , Dead = death_check(Enemy_Health , end_match , win , Health , Dead)
                    if end_match == True:
                        break
                    Health , Defence = enemy_turn(Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power , enemy , Health , Defence)
                    end_match  , win , Dead = death_check(Enemy_Health , end_match , win , Health , Dead)
                    if end_match == True:
                        break
                    print(end_match)
                if start == False:
                    Health , Defence = enemy_turn(Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power , enemy , Health , Defence)
                    end_match  , win , Dead = death_check(Enemy_Health , end_match , win , Health , Dead)
                    if end_match == True:
                        break
                    Enemy_Health , Enemy_Defence , magic_tokens = player_turn(Enemy_Health , Enemy_Defence , Health , Attack_Power , Magic_Power , magic_tokens)
                    end_match  , win , Dead = death_check(Enemy_Health , end_match , win , Health , Dead)
                    if end_match == True:
                        break
                    print(end_match)
            if win == True:
                print("You win")
                print(f'Rewards: \nXP: +{enemy["XP_drop"]} \nGold: +{enemy["Gold_drop"]}')
                xp , gold = win_event(gold , xp , enemy)

        elif choice == "2":
            gold , Health , Defence , magic_tokens = shopping(gold , Health , Defence , magic_tokens)

        elif choice == "3":
            display_stats(Level , gold , xp , Health , Defence , magic_tokens , Attack_Power , Magic_Power )
            print("="*30)

        elif choice == "4":
            chart_history()

        elif choice == "5":
            enemy = enemy_select()
            Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power = enemy_scaling(enemy , Level)
            enemy_turn_tutorial(Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power , enemy , Health , Defence)
            player_turn_tutorial(Enemy_Health , Enemy_Defence , Health , Attack_Power , Magic_Power , magic_tokens)
        elif choice == "6":
            save_file(Level , Health , Defence , xp , gold , Attack_Power , Magic_Power , magic_tokens)

        else:
            print("Under Construction")
        
        if Dead == True:
            break


# load a save file and reassigns variables
def load_file(Level , Health , Defence , xp , gold , Attack_Power , Magic_Power , magic_tokens):

    print("Please Select your file:")

    for i in range(len(df)):
        print(f'## {i+1}:{df["Save Name"][i]}')
    
    while True:
        choice = input(">>")

        try:
            int(choice)
        except:
            print("Invalid Input. Try again")
        else:
            break


    choice = int(choice) - 1
    Level = df["Level"][choice]
    Health = df["Health"][choice]
    Defence = df["Defence"][choice]
    xp = df["Xp"][choice]
    gold = df["Gold"][choice]
    Attack_Power = df["Attack Power"][choice]
    Magic_Power = df["Magic Power"][choice]
    magic_tokens = df["magic tokens"][choice]



    return Level , Health , Defence , xp , gold , Attack_Power , Magic_Power , magic_tokens

def save_file(Level , Health , Defence , xp , gold , Attack_Power , Magic_Power , magic_tokens):
    print("Enter Save name")
    name = input(">>")

    index = len(df) + 1
    df["Save Name"][index] = name
    df["Level"][index] = Level 
    df["Health"][index] = Health 
    df["Defence"][index] = Defence 
    df["Xp"][index] = xp 
    df["Gold"][index] = gold
    df["Attack Power"][index] = Attack_Power
    df["Magic Power"][index] = Magic_Power 
    df["magic tokens"][index] = magic_tokens

    print("Game saved")




