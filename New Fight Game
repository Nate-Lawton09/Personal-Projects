        else:
            
            choice = str(int(choice) - 1)
            
            print("Are you sure? y/n")
        confirm = input(">>")
        if confirm.lower() == "y":
            
            if choice == "0" and gold >= 10:
                
                magic_tokens = magic_tokens + 3
