    return start



#scale the enemy
def enemy_scaling(enemy , Level):
    Enemy_Health = enemy["Health"] * Level
    Enemy_Defence = enemy["Defence"] * Level
    Enemy_Magic_Power = enemy["Magic_Power"] * Level
    Enemy_Attack_Power = enemy["Attack_Power"] * Level

    return Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power



# Check the match isnt over
def death_check(enemy_health , end_match , win , Health , Dead):
    if Health <= 0 :
        end_match = True
        Dead = True
    if enemy_health <= 0:
        end_match = True
        win = True
    return end_match , win , Dead

def win_event(gold , xp , enemy):
    gold = gold + enemy["Gold_drop"]
    xp = xp + enemy["XP_drop"]

    return xp , gold

# enemy turn
def enemy_turn(EHealth , EDefence , Attack_Power , Magic_Power , enemy , Health , Defence):
    print("=" * 30)
    print(f'Enemy Class: {enemy["Class"]} \nHealth: {EHealth} \nDefence: {EDefence} ')
    
    attack = random.choice(list(enemy_attack_types.values()))
    attack_strength = attack["Strength"] * Attack_Power

    print(f'Enemy uses a {attack["Name"]}')
    print(f"Attack strength {attack_strength}")
    
    if "magic" in attack["Name"].lower():
        attack_strength = attack_strength * Magic_Power
        print(f"Magic amplifies the strength of the attack to {attack_strength}")
    

    if attack_strength > Defence :
        print("This attack is too strong to dodge")
        Health = Health - attack_strength

    else: 
        print("Roll an odd number to dodge")
        dodge = dice_roll()
        if ".5" in str(dodge / 2) and attack_strength<= Defence:
            print("Attack succesfully dodged")
            Defence = Defence = attack_strength
        else:
            print("Failed to dodge attack")
            Health = Health - attack_strength
    return Health , Defence


# player turn
def player_turn(EHealth , EDefence , Health , Attack_Power , Magic_Power , magic_tokens):
    print("=" * 30)
    print(f'Health: {Health} \nDefence: {Defence}')

    while True:
        print("Attack options:")
        print("## 1. Melee")
        print("## 2. Magic")

        choice = input(">>")

        try:
            int(choice)
        except:
            print("Invalid Input. Try again")
        else:
            
            print("Roll for attack")
            if choice == "1":
                attack_strength_1 = dice_roll()
                #attack_strength_2 = dice_roll()
                attack_strength = attack_strength_1 * Attack_Power
                break
        
            elif choice == "2" and magic_tokens != 0:
                magic_tokens = magic_tokens - 1
                attack_strength_1 = dice_roll()
                #attack_strength_2 = dice_roll()
                attack_strength = (attack_strength_1 * Attack_Power) * Magic_Power
                break
            elif choice == "2" and magic_tokens == 0:
                print("You cannot perform magic attacks without tokens")
            else:
                print("Invalid Input. Try again")
        
    print(f"Your attack is {attack_strength}")
    ###roll to hit
    print("Roll an even number to make a successfull attack")
    accuracy = dice_roll()
    if ".0" in str(accuracy / 2):
        if attack_strength > EDefence:
            EHealth = EHealth - attack_strength
        else:
            EDefence = EDefence - attack_strength
    else:
        print("Attack failed")

    ###enemy take damage


    return EHealth , EDefence , magic_tokens

