#Dice quick time
def dice_roll():

    user_input = 0
    flag = False
    while flag != True:
        for i in range(len(dice)):
        
            try:
                user_input = inputimeout( prompt = f">> {dice[i]}" , timeout = 0.2)
            except:
              
                print("\033[F\033[K", end="")
                
            else:
                user_input = dice[i]
                flag = True
                break
    return user_input


# level up
def level_up(Level , xp , Magic_Power , Attack_Power):
    if xp >= (Level*100):
        xp = 0
        Level = Level + 1
        Magic_Power = Magic_Power + 2
        Attack_Power = Attack_Power + 2

        print(">>Level Up<<")
        print(f">>Level {Level}<<")

    return Level , xp , Magic_Power , Attack_Power



# Select an enemy
