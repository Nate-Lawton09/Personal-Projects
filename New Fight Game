# Player variables

Level = 1

xp = 0
gold = 0

Health = 50
Defence = 30

Magic_Power = 3
Attack_Power = 3

magic_tokens = 3

start = False

inventory = []

end_match = False
win = False
# enemy variables
enemies = {1 :{"Class":"Soldier" , "Health":50 , "Defence":25 , "Magic_Power":3 , "Attack_Power":3 , "XP_drop":10 , "Gold_drop":5},
           2 :{"Class":"Brute" , "Health":100 , "Defence":10 , "Magic_Power":1 , "Attack_Power":5 , "XP_drop":15 , "Gold_drop":10},
           3 :{"Class":"Warlock" , "Health":50 , "Defence":50 , "Magic_Power":5 , "Attack_Power":2 , "XP_drop":5 , "Gold_drop":5}
           }
