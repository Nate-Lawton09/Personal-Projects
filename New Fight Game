dice = [1,2,3,4,5,6]


##Functions


#Main Menu
def Main_Menu():
    print("=" * 30)
    print("## 1. Fight an enemy")
    print("## 2. Shop")
    print("## 3. Boss Fight")
    print("## 4. View Stats")
    print("## 5. View History")
    print("=" * 30)
    while True:
        choice = input(">>")

        try:
            int(choice)
        except:
            print("Invalid Input. Try Again")
        else:
            break
    return choice

#Dice quick time
def dice_roll():

    user_input = 0
    flag = False
    while flag != True:
        for i in range(len(dice)):
        
            try:
                user_input = inputimeout( prompt = f">> {dice[i]}" , timeout = 0.2)
            except:
              
                print("\033[F\033[K", end="")
                
            else:
                user_input = dice[i]
                flag = True
                break
    return user_input


# level up
def level_up(Level , xp , Magic_Power , Attack_Power):
    if xp >= (Level*100):
        xp = 0
        Level = Level + 1
        Magic_Power = Magic_Power + 2
        Attack_Power = Attack_Power + 2

        print(">>Level Up<<")
        print(f">>Level {Level}<<")

    return Level , xp , Magic_Power , Attack_Power



# Select an enemy
def enemy_select():
    enemy = random.choice(list(enemies.values()))
    print(f'Opponent: {enemy["Class"]}')
    return enemy

#decide wether player attacks or defends first
def decide_starter():
    #print("Would you like to use luck?") 

    coin = random.randint(1,2)
    if coin == 1:
        start = True
        print("You play first")
    else:
        start = False
        print("Opponent plays first")
    
    return start



#scale the enemy
def enemy_scaling(enemy , Level):
    Enemy_Health = enemy["Health"] * Level
    Enemy_Defence = enemy["Defence"] * Level
    Enemy_Magic_Power = enemy["Magic_Power"] * Level
    Enemy_Attack_Power = enemy["Attack_Power"] * Level

    return Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power



# Check the match isnt over
def death_check(enemy , end_match , win):
    if Health <= 0 :
        end_match = True
        win = True
    if enemy["Health"] <= 0:
        end_match = True
    return end_match , win

def win_event(gold , xp , enemy):
    gold = gold + enemy["Gold_drop"]
    xp = xp + enemy["XP_drop"]

    return xp , gold

# enemy turn
def enemy_turn(EHealth , EDefence , Attack_Power , Magic_Power , enemy , Health , Defence):
    print("=" * 30)
    print(f'Enemy Class: {enemy["Class"]} \nHealth: {EHealth} \nDefence: {EDefence} ')
    
    attack = random.choice(list(enemy_attack_types.values()))
    attack_strength = attack["Strength"] * Attack_Power

    print(f'Enemy uses a {attack["Name"]}')
    print(f"Attack strength {attack_strength}")
    
    if "magic" in attack["Name"].lower():
        attack_strength = attack_strength * Magic_Power
        print(f"Magic amplifies the strength of the attack to {attack_strength}")
    

    if attack_strength > Defence :
        print("This attack is too strong to dodge")
        Health = Health - attack_strength

    else: 
        print("Roll an odd number to dodge")
        dodge = dice_roll()
        if ".5" in str(dodge / 2) and attack_strength<= Defence:
            print("Attack succesfully dodged")
            Defence = Defence = attack_strength
        else:
            print("Failed to dodge attack")
            Health = Health - attack_strength
    return Health , Defence


# player turn
def player_turn(EHealth , EDefence , Health , Attack_Power , Magic_Power , magic_tokens):
    print("=" * 30)
    print(f'Health: {Health} \nDefence: {Defence}')

    while True:
        print("Attack options:")
        print("## 1. Melee")
        print("## 2. Magic")

        choice = input(">>")

        try:
            int(choice)
        except:
            print("Invalid Input. Try again")
        else:
            
            print("Roll for attack")
            if choice == "1":
                attack_strength_1 = dice_roll()
                #attack_strength_2 = dice_roll()
                attack_strength = attack_strength_1 * Attack_Power
                break
        
            elif choice == "2" and magic_tokens != 0:
                magic_tokens = magic_tokens - 1
                attack_strength_1 = dice_roll()
                #attack_strength_2 = dice_roll()
                attack_strength = (attack_strength_1 * Attack_Power) * Magic_Power
                break
            elif choice == "2" and magic_tokens == 0:
                print("You cannot perform magic attacks without tokens")
            else:
                print("Invalid Input. Try again")
        
    print(f"Your attack is {attack_strength}")
    ###roll to hit
    print("Roll an even number to make a successfull attack")
    accuracy = dice_roll()
    if ".0" in str(accuracy / 2):
        if attack_strength > EDefence:
            EHealth = Enemy_Health - attack_strength
        else:
            EDefence = EDefence - attack_strength
    else:
        print("Attack failed")

    ###enemy take damage


    return EHealth , EDefence , magic_tokens


#######

def display_stats():
    print(f'Level:{Level} \nGold:{gold} \nXP: {xp} \nHealth: {Health} \nDefence: {Defence} \nMagic Tokens: {magic_tokens} \nAttack Power: {Attack_Power} \n Magic Power: {Magic_Power}')
#System##########################################################################################################################################
while True:
    win = False
    end_match = False
    Level , xp , Magic_Power , Attack_Power = level_up(Level , xp , Magic_Power , Attack_Power)
    choice = Main_Menu()

    if choice == "1":
        enemy = enemy_select()
        start = decide_starter()
        Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power = enemy_scaling(enemy , Level)


        while end_match == False:
            if start == True:
                Enemy_Health , Enemy_Defence , magic_tokens = player_turn(Enemy_Health , Enemy_Defence , Health , Attack_Power , Magic_Power , magic_tokens)
                end_match  , win = death_check(enemy , end_match , win)
                if end_match == True:
                    break
                Health , Defence = enemy_turn(Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power , enemy , Health , Defence)
                end_match , win = death_check(enemy , end_match , win)
                if end_match == True:
                    break
            
            if start == False:
                Health , Defence = enemy_turn(Enemy_Health , Enemy_Defence , Enemy_Attack_Power , Enemy_Magic_Power , enemy , Health , Defence)
                end_match , win = death_check(enemy , end_match , win)
                if end_match == True:
                    break
                Enemy_Health , Enemy_Defence , magic_tokens = player_turn(Enemy_Health , Enemy_Defence , Health , Attack_Power , Magic_Power , magic_tokens)
                end_match , win = death_check(enemy , end_match , win)
                if end_match == True:
                    break
        if win == True:
            print("You win")
            print(f'Rewards: \nXP: +{enemy["XP_drop"]} \nGold: +{enemy["Gold_drop"]}')
            xp , gold = win_event(gold , xp , enemy)

    if choice == "4":
        display_stats()
        print("="*30)

    else:
        print("Under Construction")



