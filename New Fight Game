    enemy = random.choice(list(enemies.values()))
    print(f'Opponent: {enemy["Class"]}')
    enemy["Times_fought"] = enemy["Times_fought"] + 1
    return enemy

def chart_history():
    labels = [enemy["Class"] for enemy in enemies.values()]
    times_fought = [enemy["Times_fought"] for enemy in enemies.values()]

    plt.figure()
    plt.pie(times_fought, labels=labels, autopct="%1.1f%%")
    plt.title("Session Fight History")
    plt.show()


